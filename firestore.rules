rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPER FUNCTIONS ────────────────────────────────────────────────────

    // [SECURITY] Returns true only if the update touches exclusively the
    // whitelisted engagement counter fields. This prevents a malicious actor
    // from sneaking in content changes alongside a counter update.
    function isOnlyCounterUpdate() {
      let allowed = ['likes', 'views', 'comments', 'reshares', 'updatedAt'];
      let incoming = request.resource.data.diff(resource.data).affectedKeys();
      return incoming.hasOnly(allowed);
    }

    // [SECURITY] Validates that a counter field only ever increases or is
    // set via FieldValue.increment(). The value must be a non-negative int
    // and can only go up, preventing counter manipulation / negative attacks.
    function isValidIncrement(field) {
      return !(field in request.resource.data.diff(resource.data).affectedKeys())
        || (request.resource.data[field] is int
            && request.resource.data[field] >= 0
            && request.resource.data[field] >= resource.data[field]);
    }

    // ── Submissions ─────────────────────────────────────────────────────────
    match /submissions/{submissionId} {

      // [UNCHANGED] Owner creates, userId must match auth uid.
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      // [UNCHANGED] Owner sees all statuses; others see only approved.
      allow read: if request.auth != null
                  && (resource.data.status == 'approved'
                      || resource.data.userId == request.auth.uid);

      // [SECURITY FIX] Submission update is split into two strict branches:
      //
      // Branch 1 — Owner edits their own DRAFT (full content write allowed).
      //   - Must be the document owner.
      //   - Status must still be 'draft' (cannot self-approve).
      //   - Cannot change the userId field (prevents ownership transfer).
      //
      // Branch 2 — Anyone increments engagement COUNTERS on APPROVED posts.
      //   - Post must be approved.
      //   - ONLY the counter fields (likes/views/comments/reshares) may change.
      //   - Each counter must be a non-negative integer and may only increase.
      //   - Title, content, userId, status — all immutable by non-owners.
      allow update: if request.auth != null && (

        // Branch 1: owner updates their own content
        (
          resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId   // no ownership transfer
        )

        // Branch 2: engagement counter increments on approved posts
        || (
          resource.data.status == 'approved'
          && isOnlyCounterUpdate()
          && isValidIncrement('likes')
          && isValidIncrement('views')
          && isValidIncrement('comments')
          && isValidIncrement('reshares')
        )
      );

      // [UNCHANGED] Hard delete disabled — use soft-delete via status field.
      allow delete: if false;

      // ── Engagement subcollections ──────────────────────────────────────

      // [UNCHANGED] Each user controls only their own like document.
      match /likes/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // [UNCHANGED] Each user controls only their own reshare document.
      match /reshares/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // [UNCHANGED] Comments: create your own, edit/delete only your own.
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.userId == request.auth.uid;
        allow update, delete: if request.auth != null
                               && resource.data.userId == request.auth.uid;
      }
    }

    // ── User documents ───────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /bookmarks/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /likes/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /following/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // [UNCHANGED] Anyone may follow or unfollow; only they can touch their follower doc.
      match /followers/{followerId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null
                               && request.auth.uid == followerId;
      }

      match /tokens/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /restacks/{postId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // [SECURITY FIX] Notification spam prevention.
      //
      // Previously: allow create: if request.auth != null;
      // This let ANY authenticated user write a notification to ANY user's
      // inbox — trivially exploitable for spam or phishing.
      //
      // Fix: Notifications are created exclusively by Cloud Functions
      // (server-side admin SDK, which bypasses rules). No client may create
      // them directly. A user may only read, mark as read (update), or
      // delete their own notifications.
      match /notifications/{notifId} {
        // [SECURITY] create is intentionally DENIED to all clients.
        // Cloud Functions write notifications via the Admin SDK.
        allow create: if false;
        allow read, update, delete: if request.auth != null
                                    && request.auth.uid == userId;
      }

      match /collections/{colId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        match /posts/{postId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
